# ─────────────────────────────────────────────
# CORE
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# TWILIO (WhatsApp Sandbox)
# ─────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number for local PowerShell tests (E.164, e.g. whatsapp:+918639097638)
TEST_WHATSAPP_FROM=whatsapp:+91XXXXXXXXXX
# WhatsApp tap-to-choose lists (Twilio Content templates). Without these, users only see plain text.
TWILIO_WHATSAPP_QUICK_REPLY=true
# Service menu list-picker — create via: python scripts/create_service_list_content.py
TWILIO_SERVICE_SELECTION_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Shared dynamic list template for other MCQ steps (optional if each flow JSON has twilio_content_sid)
TWILIO_WHATSAPP_INTERACTIVE_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Variable MCQ list pickers (2/4/5 options) — create via: python scripts/create_mcq_list_content.py --rows 2
TWILIO_MCQ_LIST_2_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MCQ_LIST_5_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MCQ_LIST_4_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# VAPI (Voice Agent)
# ─────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# ─────────────────────────────────────────────
# ELEVENLABS (TTS via Vapi)
# ─────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# ─────────────────────────────────────────────
# UPSTASH REDIS (Session Cache)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
SESSION_TTL_HOURS=24
# End in-progress chats after this many minutes without a user message (0 = disabled)
SESSION_IDLE_TIMEOUT_MINUTES=5

# ─────────────────────────────────────────────
# SUPABASE (Persistent Storage)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ─────────────────────────────────────────────
# ADMIN PANEL (/krsna)
# ─────────────────────────────────────────────
ADMIN_PASSWORD=admin@123
ADMIN_API_KEY=krsna_local_api_a1b2c3d4e5f6g7h6

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
# Public-facing base URL for this service (used by Vapi to self-reference webhook URL)
# e.g. https://aadhya.onrender.com   — no trailing slash
BASE_URL=http://localhost:8000
# Allowed CORS origins — comma-separated. Use * for local dev only.
# Production example: https://omni-rho-snowy.vercel.app (origin only — no /krsna path)
# e.g. https://admin.tatvaops.com,https://tatvaops.com
CORS_ORIGINS=*
