{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/krsna/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/krsna", "destination": "/krsna/" },
    { "source": "/krsna/(.*)", "destination": "/index.html" },
    { "source": "/", "destination": "/krsna/" }
  ]
}
